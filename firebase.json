{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaseignore",
      "**/.*",
      "**/node_modules/**",
      "dist/**",
      "electron/**",
      "engine/**",
      "www/**",
      "functions/**",
      "android/**",
      "ios/**",
      ".github/**",
      ".githubworkflows/**",
      "package.json",
      "package-lock.json",
      "*.asar",
      "*.dll",
      "*.bin",
      "*.dat",
      "*.pak",
      "*.icns",
      "*.zip",
      "*.txt",
      "build_marker.txt",
      "capacitor.config.*",
      "firestore.rules",
      "storage.rules",
      "build-output.txt",
      "installer.nsh",
      "*.exe",
      "*.apk",
      "downloads/**"
    ],
    "headers": [
      {
        "source": "downloads/**",
        "headers": [
          { "key": "Content-Type", "value": "application/octet-stream" },
          { "key": "Content-Disposition", "value": "attachment" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/download.html",
        "destination": "/download.html"
      },
      {
        "source": "/downloads/**",
        "destination": "/downloads/**"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
